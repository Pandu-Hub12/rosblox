local map = {
    [93978595733734] = "VIP",
}

local base = "https://raw.githubusercontent.com/Pandu-Hub12/rosblox/main/"

local scriptName = map[game.PlaceId] or "all_map"

local success, result = pcall(function()
    return game:HttpGet(base .. scriptName)
end)

if success then
    loadstring(result)()
else
    warn("Gagal load script")
end